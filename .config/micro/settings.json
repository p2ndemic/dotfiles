    "ft:graphql": {
        "tabsize": 2
    },
    "ft:haskell": {
        "tabsize": 2
    },
    "ft:html": {
        "tabsize": 2
    },
    "ft:html5": {
        "tabsize": 2
    },
    "ft:jinja2": {
        "tabsize": 2
    },
    "ft:json": {
        "tabsize": 2
    },
    "ft:jsonnet": {
        "tabsize": 2
    },
    "ft:justfile": {
        "tabstospaces": false
    },
    "ft:lisp": {
        "tabsize": 2
    },
    "ft:lua": {
        "tabsize": 2
    },
    "ft:makefile": {
        "tabstospaces": false
    },
    "ft:markdown": {
        "tabsize": 2
    },
    "ft:meson": {
        "tabsize": 2
