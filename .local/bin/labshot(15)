#!/usr/bin/env bash
# labshot — screenshot utility for Labwc / Wayland
# Usage: labshot [OPTIONS] (copy|save|copysave|edit) [fullscreen|area] [FILE|-]

set -o pipefail

# ─── Defaults ────────────────────────────────────────────────────────────────

DATE_FORMAT="%d%m%Y_%H%M%S"
SCREENSHOT_DIR="${XDG_SCREENSHOTS_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots}"
FILE="$SCREENSHOT_DIR/$(date +"$DATE_FORMAT").png"

ACTION="copysave"
MODE="fullscreen"
CURSOR=false
FREEZE=false
WAIT=0
EXPIRE_TIME=2000
HYPRPICKER_PID=""
LOCK_FILE="/tmp/labshot.lock"

# ─── Functions ────────────────────────────────────────────────────────────────

usage() {
    cat >&2 <<EOF
Usage: labshot [OPTIONS] (copy|save|copysave|edit) [fullscreen|area] [FILE|-]

Options:
  -c, --cursor            Capture mouse cursor
  -f, --freeze            Freeze screen during area selection (requires hyprpicker)
  -w N, --wait=N          Delay N seconds before capture
  -e MS, --expire-time=MS Notification expire time in ms (default: 2000)
  -h, --help              Show this help

Actions:  copy | save | copysave (default) | edit
Modes:    fullscreen (default) | area
EOF
    exit "${1:-1}"
}

stop_freeze() {
    [[ -n "$HYPRPICKER_PID" ]] && kill "$HYPRPICKER_PID" 2>/dev/null
    HYPRPICKER_PID=""
}

start_freeze() {
    if ! command -v hyprpicker &>/dev/null; then
        echo "labshot: warning: hyprpicker not found, --freeze disabled" >&2
        return
    fi
    if pgrep -x hyprpicker &>/dev/null; then
        pkill -x hyprpicker
        sleep 0.1
    fi
    hyprpicker -r -z -t &
    HYPRPICKER_PID=$!
    sleep 0.3  # allow hyprpicker to render before slurp opens
}

cleanup() {
    stop_freeze
}

show_notification() {
    local title="$1"
    local body="${2:-}"
    local with_button="${3:-false}"

    if [[ "$with_button" == true ]]; then
        local chosen
        chosen=$(notify-send \
            -a "labshot" \
            -i "$FILE" \
            -t "$EXPIRE_TIME" \
            -A "show=Show file" \
            "$title" "$body")
        if [[ "$chosen" == "show" ]]; then
            dbus-send --session \
                --dest=org.freedesktop.FileManager1 \
                --type=method_call \
                /org/freedesktop/FileManager1 \
                org.freedesktop.FileManager1.ShowItems \
                array:string:"file://$FILE" string:""
        fi
    else
        notify-send -a "labshot" -t "$EXPIRE_TIME" "$title" "$body"
    fi
}

# ─── Traps ────────────────────────────────────────────────────────────────────

trap cleanup EXIT
trap 'exit 1' INT TERM

# ─── Lock ─────────────────────────────────────────────────────────────────────

exec 9>"$LOCK_FILE"
flock -n 9 || { echo "labshot: already running" >&2; exit 1; }

# ─── Argument parsing ─────────────────────────────────────────────────────────

POSITIONAL=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--cursor)        CURSOR=true;              shift ;;
        -f|--freeze)        FREEZE=true;              shift ;;
        -w|--wait)          WAIT="$2";                shift 2 ;;
        --wait=*)           WAIT="${1#*=}";           shift ;;
        -e|--expire-time)   EXPIRE_TIME="$2";         shift 2 ;;
        --expire-time=*)    EXPIRE_TIME="${1#*=}";    shift ;;
        -h|--help)          usage 0 ;;
        --)                 shift; POSITIONAL+=("$@"); break ;;
        -*)                 echo "labshot: unknown option: $1" >&2; usage ;;
        *)                  POSITIONAL+=("$1");       shift ;;
    esac
done

for arg in "${POSITIONAL[@]}"; do
    case "$arg" in
        copy|save|copysave|edit) ACTION="$arg" ;;
        fullscreen|screen)       MODE="fullscreen" ;;
        area)                    MODE="area" ;;
        *)                       FILE="$arg" ;;
    esac
done

# ─── Prepare output directory ─────────────────────────────────────────────────

if [[ "$ACTION" != "copy" && "$FILE" != "-" ]]; then
    mkdir -p "$(dirname "$FILE")" || {
        echo "labshot: cannot create directory: $(dirname "$FILE")" >&2
        exit 1
    }
fi

# ─── Wait before capture ──────────────────────────────────────────────────────

(( WAIT > 0 )) && sleep "$WAIT"

# ─── Area selection ───────────────────────────────────────────────────────────

REGION=""
if [[ "$MODE" == "area" ]]; then
    [[ "$FREEZE" == true ]] && start_freeze
    REGION=$(slurp) || { exit 0; }
    stop_freeze
fi

# ─── Build grim args ──────────────────────────────────────────────────────────

GRIM_ARGS=(-t png -l 0)
[[ "$CURSOR" == true ]] && GRIM_ARGS+=(-c)
[[ -n "$REGION" ]]      && GRIM_ARGS+=(-g "$REGION")

# ─── Capture and action ───────────────────────────────────────────────────────

case "$ACTION" in
    copy)
        grim "${GRIM_ARGS[@]}" - | wl-copy || exit 1
        show_notification "Screenshot copied to clipboard"
        ;;
    save)
        grim "${GRIM_ARGS[@]}" "$FILE" || exit 1
        show_notification "Screenshot saved" "$FILE" true
        ;;
    copysave)
        grim "${GRIM_ARGS[@]}" - | tee "$FILE" | wl-copy || exit 1
        show_notification "Screenshot saved" "$FILE" true
        ;;
    edit)
        if [[ "$FILE" == "-" ]]; then
            grim "${GRIM_ARGS[@]}" - | satty --filename - || exit 0
        else
            grim "${GRIM_ARGS[@]}" - | satty --filename - --output-filename "$FILE" || exit 0
            show_notification "Screenshot saved" "$FILE" true
        fi
        ;;
esac
