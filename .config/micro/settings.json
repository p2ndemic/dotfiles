        "tabstospaces": false
    },
    "ft:elixir": {
        "tabsize": 2
    },
    "ft:forth": {
        "tabstospaces": false
    },
    "ft:gdscript": {
        "tabstospaces": false
    },
    "ft:gleam": {
        "tabsize": 2
    },
    "ft:go": {
        "tabstospaces": false
    },
    "ft:gomod": {
        "tabstospaces": false
