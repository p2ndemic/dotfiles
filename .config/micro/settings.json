    },
    "ft:scala": {
        "tabsize": 2
    },
    "ft:shell": {
        "tabsize": 4
    },
    "ft:svelte": {
        "tabsize": 2
    },
    "ft:terraform": {
        "tabsize": 2
    },
    "ft:tex": {
        "tabsize": 2
