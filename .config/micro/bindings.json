{
    "Alt-t": "command:toggle hltaberrors",
    "Alt-w": "command:toggle hltrailingws",
    "Alt-o": "command:set showchars 'tab=›,space=·'",
    "Alt-i": "command:set showchars ''",

    "\u001bе": "command:toggle hltaberrors",
    "\u001bц": "command:toggle hltrailingws",
    "\u001bщ": "command:set showchars 'tab=›,space=·'",
    "\u001bш": "command:set showchars ''",

    "F3": "FindNext",
    "ShiftF3": "FindPrevious",

    "Ctrl-Shift-Down": "FindNext",
    "Ctrl-Shift-Up": "FindPrevious"
}
