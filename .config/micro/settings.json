    "ft:yaml": {
        "tabsize": 2
    },
    "ft:zsh": {
        "tabsize": 4
    },
    "helpsplit": "vsplit",
    "hlsearch": true,
    "matchbracestyle": "highlight",
    "mkparents": true,
    "parsecursor": true,
    "paste": false,
    "rmtrailingws": false,
    "savecursor": false,
    "saveundo": false,
    "scrollbar": true,
    "scrollbarchar": "│",
    "scrollspeed": 3,
    "smartpaste": true,
    "softwrap": true,
    "statusformatl": "$(filename) $(modified)$(overwrite) $(status.paste)| ft:$(opt:filetype) | $(opt:fileformat) | $(opt:encoding)",
    "statusformatr": "$(line):$(col) | $(lines) ",
    "tabhighlight": false,
    "tabmovement": true,
    "tabsize": 4,
    "tabstospaces": true,
    "truecolor": "on",
    "useprimary": true,
    "wordwrap": true,
    "xterm": false
}
